PORT=3000
SESSION_SECRET=world-cup-2026-local-secret
ADMIN_PASSWORD=password
DB_FILE=data/predictions.db
NODE_ENV=development
TRUST_PROXY=0

# Bucket backup settings (for Railway cron job)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Optional for S3-compatible providers (Cloudflare R2, MinIO, etc.)
S3_ENDPOINT=
# Keep true for most S3-compatible providers
S3_FORCE_PATH_STYLE=true
# Folder/prefix within the bucket
BACKUP_PREFIX=worldcup2026_ww
